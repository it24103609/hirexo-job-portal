PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
CLIENT_URL=https://<your-frontend-domain>
CLIENT_URLS=https://<your-frontend-domain>
ALLOW_VERCEL_PREVIEWS=true
JWT_ACCESS_SECRET=<set-strong-random-secret-min-32-chars>
JWT_REFRESH_SECRET=<set-strong-random-secret-min-32-chars>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SMTP_HOST=<smtp-host>
SMTP_PORT=587
SMTP_USER=<smtp-user>
SMTP_PASS=<smtp-password>
SMTP_FROM="Hirexo <no-reply@hirexo.com>"
UPLOAD_DIR=uploads/resumes
MAX_FILE_SIZE=2097152
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
ADMIN_EMAIL=admin@hirexo.com
ADMIN_PASSWORD=<set-strong-admin-password>
